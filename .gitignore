## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Rider
.idea/
*.sln.iml
*.sln

# Visual Studio Code
.vscode/
*.code-workspace

# Visual Studio cache/options directory
.vs/

# Nuget personal use only message
# build folder
/build/
/bld/
/obj/
/out/
/bin/
/Bin/
/packages/
.nupkg

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Test Results
/TestResults/

# Local .NET Core Cli
.dotnet/

# Dalamud specific
*.dll
*.pdb
dalamud.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
.directory

# Logs
logs/
*.log

latest.zip
*.zip

